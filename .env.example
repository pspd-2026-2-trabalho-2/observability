# ---- observability: variáveis de ambiente ----
# Copie para .env e ajuste conforme necessário. Todos os valores abaixo já são
# os defaults usados se o .env não existir — copiar este arquivo é opcional
# para rodar a stack, só é necessário se quiser mudar algum valor.

# Postgres (mesmo banco usado pelo patient-data-service)
POSTGRES_USER=pspd
POSTGRES_PASSWORD=pspd
POSTGRES_DB=hospital

# Deve ser o mesmo valor usado pelo gateway-authorization-service
# (JWT_SECRET no .env dele) para os tokens serem aceitos.
JWT_SECRET=secret-key

# Deve ser o mesmo valor usado pelo data-transform-service
# (PSEUDONYM_SALT no .env dele) para os IDs anonimizados baterem entre execuções.
PSEUDONYM_SALT=pspd-troque-este-salt

# Login do Grafana local
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
