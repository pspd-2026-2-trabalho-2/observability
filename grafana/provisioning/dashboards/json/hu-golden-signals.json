        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (job) (up{namespace=~\"$k8s_namespace|\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Instâncias ativas por serviço",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Nº de instâncias ativas (targets UP) do API Gateway — mesmo dado do painel \"Instâncias ativas por serviço\", filtrado só pro gateway.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "id": 10,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(up{job=~\"(.*/)?api-gateway\", namespace=~\"$k8s_namespace|\"})",
          "legendFormat": "api-gateway",
          "refId": "A"
        }
      ],
      "title": "Pods disponíveis (API Gateway)",
      "type": "stat"
    }
