{
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": [],
      "title": "Visão geral / gRPC",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (job) (rate(grpc_server_handled_total{namespace=~\"$k8s_namespace|\"}[$agrupamento]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Throughput gRPC por serviço",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(grpc_server_handling_seconds_bucket{job=~\"(.*/)?(patient-data-service|data-transform-service)\", namespace=~\"$k8s_namespace|\"}[$agrupamento])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Latência p95 gRPC (patient-data / data-transform)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (job) (rate(grpc_server_handled_total{job!~\"(.*/)?auth-service\", code!=\"OK\", namespace=~\"$k8s_namespace|\"}[$agrupamento]))",
          "legendFormat": "{{job}} error",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (job) (rate(grpc_server_handled_total{job=~\"(.*/)?auth-service\", grpc_code!=\"OK\", namespace=~\"$k8s_namespace|\"}[$agrupamento]))",
          "legendFormat": "{{job}} error",
          "refId": "B"
        }
      ],
      "title": "Taxa de erro gRPC",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 101,
      "panels": [],
      "title": "Banco de Dados",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (query) (rate(db_queries_total{namespace=~\"$k8s_namespace|\"}[$agrupamento]))",
          "legendFormat": "{{query}} ok",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (query) (rate(db_queries_total{status=\"error\", namespace=~\"$k8s_namespace|\"}[$agrupamento]))",
          "legendFormat": "{{query}} error",
          "refId": "B"
        }
      ],
      "title": "Consultas ao banco (req/s + erros)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, query) (rate(db_query_duration_seconds_bucket{namespace=~\"$k8s_namespace|\"}[$agrupamento])))",
          "legendFormat": "{{query}}",
          "refId": "A"
        }
      ],
      "title": "Latência de consulta ao banco (p95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 102,
