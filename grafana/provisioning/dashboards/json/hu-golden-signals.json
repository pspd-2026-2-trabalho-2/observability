      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (operation, level) (rate(fhir_transforms_total{namespace=~\"$k8s_namespace|\"}[$agrupamento]))",
          "legendFormat": "{{operation}} ({{level}})",
          "refId": "A"
        }
      ],
      "title": "Transformações FHIR por operação/nível",
