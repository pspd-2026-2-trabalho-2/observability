      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "process_resident_memory_bytes{namespace=~\"$k8s_namespace|\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Memória residente por serviço",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Nº de instâncias ativas (targets UP) por serviço. sum by(job)(up) = 1 por serviço no Compose; no cluster = nº de pods descobertos/réplicas em execução.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "id": 9,
      "options": {
        "legend": {
          "displayMode": "list",
